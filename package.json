{
  "name": "autonomous-drone-mission-simulator",
  "version": "1.0.0",
  "description": "Local-first React and TypeScript simulator for multi-drone public-safety missions, tactical route control, replay, and evidence exports.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/loganlewisw1112-create/Autonomous-Drone-Simulator.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "classroom": "vite build --mode classroom && node server/classroom.mjs",
    "classroom:relay": "node server/classroom.mjs",
    "classroom:desktop": "vite build --mode classroom && electron desktop/classroom/main.mjs",
    "classroom:desktop:launch": "electron desktop/classroom/main.mjs",
    "fixtures": "node tools/fixtures/index.mjs",
    "fixtures:terrain": "node tools/fixtures/terrain.mjs",
    "fixtures:buildings": "node tools/fixtures/buildings.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "lint": "eslint src",
    "assert:bundles": "node scripts/assert-bundle-isolation.mjs",
    "assert:fixtures": "node scripts/assert-realism-fixture-budget.mjs",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^1.8.0",
    "maplibre-gl": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "ws": "^8.21.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^37.10.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
