# MapLibre tile source — uses free OpenStreetMap tiles by default, no key needed
# To use Maptiler (satellite tiles), get a free key at https://cloud.maptiler.com
VITE_MAPTILER_KEY=

# Simulation seed override (optional — scenario YAML takes precedence)
VITE_DEFAULT_SEED=42

# Optional: instructor unlock digest for hosted classroom (Vercel dashboard).
# Local LAN classroom: leave unset — the first access code typed in the UI becomes
# the school secret automatically (written to gitignored local-secrets/ by the relay).
# Never commit a real digest.
# VITE_INSTRUCTOR_ACCESS_HASH=

# Optional: override classroom WebSocket URL (advanced). Default is same-origin.
# VITE_CLASSROOM_WS_URL=

# Optional: preferred relay base URL for the web Yes/probe dialog (e.g. http://127.0.0.1:8080).
# Browser/Vercel builds only probe — they never spawn the Node relay.
# VITE_CLASSROOM_RELAY_URL=
