# MapLibre tile source — uses free OpenStreetMap tiles by default, no key needed
# To use Maptiler (satellite tiles), get a free key at https://cloud.maptiler.com
VITE_MAPTILER_KEY=

# Simulation seed override (optional — scenario YAML takes precedence)
VITE_DEFAULT_SEED=42

# App port
VITE_PORT=5173

# Classroom instructor signup unlock — SHA-256 hex of your agency access code.
# Generate: node -e "import { createHash } from 'crypto'; console.log(createHash('sha256').update('YOUR-CODE').digest('hex'))"
# Never put the plaintext code in this file or in the client bundle.
# VITE_INSTRUCTOR_ACCESS_HASH=
